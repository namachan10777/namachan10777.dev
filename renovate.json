{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Keep the TypeScript 6 API for tooling compatibility",
      "matchManagers": ["npm"],
      "matchDepNames": ["typescript"],
      "allowedVersions": "<7"
    },
    {
      "description": "Auto-merge npm package updates",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr"
    }
  ]
}
