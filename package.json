{
  "name": "namachan10777-dev",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@eslint/js": "10.0.1",
    "@iconify-json/iconoir": "^1.2.10",
    "@iconify/json": "^2.2.461",
    "@qwik.dev/core": "^2.0.0-beta.31",
    "@qwik.dev/router": "^2.0.0-beta.31",
    "@svgx/core": "^1.0.1",
    "@types/node": "25.6.0",
    "bun-types": "^1.3.12",
    "eslint": "10.2.0",
    "eslint-plugin-qwik": "^1.19.2",
    "fast-xml-parser": "^5.5.11",
    "globals": "17.5.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.2",
    "ts-morph": "^27.0.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "undici": "^8.0.0",
    "unplugin-icons": "^22.5.0",
    "valibot": "^1.3.1",
    "vite": "7.3.2",
    "vite-tsconfig-paths": "^6.0.0",
    "wrangler": "^4.81.1"
  },
  "description": "Blank project with routing included",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "overrides": {
    "vite": "7.1.11"
  },
  "private": true,
  "scripts": {
    "build": "bunx wrangler types && qwik build && bun run ./assetsignore.ts",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "bun run build && bun run ./assetsignore.ts && wrangler deploy",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "bun run build && wrangler dev --remote",
    "serve": "wrangler pages dev ./dist --compatibility-flags=nodejs_als",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "type": "module"
}
