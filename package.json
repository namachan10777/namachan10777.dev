{
  "name": "namachan10777-dev",
  "dependencies": {
    "@vanilla-extract/css": "^1.21.1",
    "isbot": "^5.1.32",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-router": "8.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.47.0",
    "@eslint/js": "10.0.1",
    "@iconify-json/iconoir": "^1.2.10",
    "@iconify/json": "^2.2.461",
    "@react-router/dev": "8.3.0",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgx/core": "^1.0.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vanilla-extract/vite-plugin": "^5.2.5",
    "bun-types": "^1.3.12",
    "eslint": "10.7.0",
    "fast-xml-parser": "^5.5.11",
    "globals": "17.7.0",
    "jiti": "^2.6.1",
    "katex": "^0.18.0",
    "prettier": "3.9.6",
    "ts-morph": "^28.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.58.1",
    "undici": "^8.0.0",
    "unplugin-icons": "^23.0.0",
    "valibot": "^1.3.1",
    "vite": "^8.0.11",
    "vitest": "4.1.10",
    "wrangler": "4.114.0"
  },
  "description": "Blank project with routing included",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "scripts": {
    "build": "bun run cf-typegen && react-router build && cp node_modules/katex/dist/katex.min.css build/client/ && cp -r node_modules/katex/dist/fonts build/client/",
    "build.types": "react-router typegen && node node_modules/@typescript/native/bin/tsc --incremental --noEmit",
    "cf-typegen": "wrangler types && react-router typegen",
    "check": "bun run cf-typegen && bun run fmt.check && bun run lint && bun run lint:sql && bun run build.types && bun run test",
    "ci": "bun run cf-typegen && bun run check",
    "deploy": "bun run build && wrangler deploy",
    "dev": "react-router dev",
    "dev.debug": "node --inspect-brk ./node_modules/@react-router/dev/bin.js dev",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "fmt:sql": "uvx sqlfluff==3.3.1 fix migrations",
    "lint": "eslint .",
    "lint:sql": "uvx sqlfluff==3.3.1 lint migrations",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "start": "react-router dev --open"
  },
  "type": "module"
}
